{
	"version": 3,
	"routes": [
		{
			"src": ".*",
			"continue": true,
			"transforms": [
				{
					"type": "request.query",
					"op": "delete",
					"target": {
						"key": "__pathname"
					}
				}
			]
		},
		{
			"src": "/_app/immutable/.+",
			"headers": {
				"cache-control": "public, immutable, max-age=31536000"
			}
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "/_app/immutable/.+",
			"status": 404,
			"continue": false
		},
		{
			"src": "^/?(?:/__data.json)?$",
			"dest": "/"
		},
		{
			"src": "^/courses/?(?:/__data.json)?$",
			"dest": "/courses"
		},
		{
			"src": "^/courses/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/courses/[slug]"
		},
		{
			"src": "^/dashboard/?(?:/__data.json)?$",
			"dest": "/dashboard"
		},
		{
			"src": "^/feed/?(?:/__data.json)?$",
			"dest": "/feed"
		},
		{
			"src": "^/login/?(?:/__data.json)?$",
			"dest": "/login"
		},
		{
			"src": "^/messages/?(?:/__data.json)?$",
			"dest": "/messages"
		},
		{
			"src": "^/notifications/?(?:/__data.json)?$",
			"dest": "/notifications"
		},
		{
			"src": "^/profile/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/profile/[username]"
		},
		{
			"src": "^/register/?(?:/__data.json)?$",
			"dest": "/register"
		},
		{
			"src": "^/search/?(?:/__data.json)?$",
			"dest": "/search"
		},
		{
			"src": "^/settings/?(?:/__data.json)?$",
			"dest": "/settings"
		},
		{
			"src": "^/upload/?(?:/__data.json)?$",
			"dest": "/upload"
		},
		{
			"src": "^/video/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/video/[slug]"
		},
		{
			"src": "/.*",
			"dest": "/![-]/catchall"
		}
	],
	"overrides": {}
}